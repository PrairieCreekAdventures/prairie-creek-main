---
import BaseLayout from '../layouts/BaseLayout.astro';
import Wildflowers from '../components/Wildflowers.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = allPosts.find(p => p.data.featured) || allPosts[0];
const journalPosts = allPosts.filter(p => p.id !== featured?.id).slice(0, 4);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const categories = [
  { slug: 'farm-life', num: '01', title: 'Farm Life', sub: 'Daily happenings with the animals, the garden, and everyone in between.', ornament: 'sprig' },
  { slug: 'recipes', num: '02', title: 'Recipes', sub: 'Cooking from the kitchen garden, grandmother\'s recipe box, and whatever\'s on the counter.', ornament: 'poppy' },
  { slug: 'hope-faith', num: '03', title: 'Hope &amp; Faith', sub: 'Adoption, answered prayers, devotionals, and the long road to now.', ornament: 'cosmos' },
  { slug: 'june-bug', num: '04', title: 'June Bug\'s Journey', sub: 'Restoring a vintage camper and everything she\'s teaching me along the way.', ornament: 'bouquet' },
  { slug: 'garden', num: '05', title: 'The Garden', sub: 'Wildflowers, raised beds, the wildflower field that\'s coming.', ornament: 'cosmos' },
  { slug: 'savvy-bunny', num: '06', title: 'Savvy Bunny', sub: 'Little stories for little readers, starring our very own heroine.', ornament: 'both' },
];
---

<BaseLayout>

<!-- HERO -->
<section class="hero">
  <div class="hero__grid">
    <div class="hero__text">
      <div class="eyebrow">
        <span class="eyebrow__bar"></span>
        <span>A lifestyle journal from Arkansas</span>
      </div>

      <h1 class="hero__wordmark">Prairie Creek</h1>
      <p class="hero__adventures">Adventures</p>

      <p class="hero__lede">
        Home to one family, a few animals, a vintage camper named June Bug, and a whole lot of hope.
      </p>

      <div class="hero__meta">
        <a href="/about" class="btn btn--primary">
          <span>Read our story</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L7 1m6 6l-6 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <span class="hero__byline">— KAYLA &amp; DAVID</span>
      </div>
    </div>

    <figure class="hero__image">
      <div class="hero__image-wrap">
        <img src="/images/uploads/adventures-on-prairie-creek-pfp-1200-x-1500-px-.png" alt="David, Kayla, and baby Savannah on the farm with a baby goat" />
      </div>
      <figcaption class="hero__caption">
        <span class="hero__caption-rule"></span>
<span>David, Kayla, and Savannah — with a baby goat who insisted on being in the picture.</span>
</figcaption>
    </figure>
  </div>
</section>

<!-- WELCOME / ABOUT TEASER -->
<section class="about-teaser">
  <div class="about-teaser__inner">
    <div class="about-teaser__left">
      <div class="eyebrow">
        <span class="eyebrow__bar"></span>
        <span>Welcome, friend</span>
      </div>
      <h2 class="about-teaser__title">
        We waited thirteen years<br/>
        <em>for this life.</em>
      </h2>
      <p class="about-teaser__body">
        For most of our marriage, David and I were waiting. For babies that didn't come, for adoptions that fell through, for a plan we couldn't make work no matter how hard we tried. Then one day we stopped waiting and started living — and that's when everything began.
      </p>
      <p class="about-teaser__body">
        We bought ten acres from my grandfather. Put a tiny house on it. Got chickens, pigs, goats, turkeys, two Great Pyrenees puppies, a mini horse, a mini zebu cow. And on New Year's Day 2026, we got the phone call that made us a family. Her name is Savannah. She's our joy.
      </p>
      <p class="about-teaser__body">
        This is where we document all of it — the farm, the recipes, the slow mornings, the hard-won hope.
      </p>
      <a href="/about" class="btn btn--ghost" style="margin-top: 1.25rem;">
        <span>Read our full story</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L7 1m6 6l-6 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div class="about-teaser__signature">Kayla &amp; David</div>
    </div>

    <div class="about-teaser__right">
     <div class="about-teaser__image-wrap">
        <img src="/images/uploads/adventures-on-prairie-creek-pfp-1200-x-1500-px-1-.png" alt="Kayla at the creek at golden hour, holding baby Savannah" />
      </div>
    </div>
  </div>
</section>

<!-- CATEGORIES -->
<section class="categories">
  <div class="categories__inner">
    <div class="section-head">
      <div class="section-head__num">Explore the journal</div>
      <h3 class="section-head__title">Things we <em>write about</em></h3>
      <p class="section-head__sub">Life on the farm is a lot of things at once. Here's where to find each kind of story.</p>
    </div>

    <div class="categories__grid">
      {categories.map(cat => (
        <a href={`/category/${cat.slug}`} class="cat-card">
          <Wildflowers variant={cat.ornament as any} size={48} class="cat-card__ornament" />
          <span class="cat-card__num">{cat.num}</span>
          <h4 class="cat-card__title" set:html={cat.title}></h4>
          <p class="cat-card__sub">{cat.sub}</p>
          <span class="cat-card__count">View stories →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- HOPE RIBBON -->
<section class="ribbon">
  <Wildflowers variant="cosmos" size={70} class="ribbon__ornament ribbon__ornament--left" />
  <Wildflowers variant="poppy" size={70} class="ribbon__ornament ribbon__ornament--right" />
  <div class="ribbon__inner">
    <div class="ribbon__eyebrow">The one-word promise</div>
    <div class="ribbon__word">hope.</div>
    <p class="ribbon__text">
      Every post, every recipe, every picture of that little face — rooted in what we've been given and who we've become. If you need hope today, you're in the right place.
    </p>
  </div>
</section>

<!-- JOURNAL / RECENT POSTS -->
<section class="journal">
  <div class="journal__inner">
    <div class="section-head">
      <div class="section-head__num">From the journal</div>
      <h3 class="section-head__title">Lately, at <em>Prairie Creek</em></h3>
      <p class="section-head__sub">The newest stories from the farm, the kitchen, and the long way home.</p>
    </div>

    <div class="journal__grid">
      {featured && (
        <article class="post post--large">
          <a href={`/journal/${featured.id}`} class="post__image">
            {featured.data.image ? (
              <img src={featured.data.image} alt={featured.data.imageAlt || featured.data.title} />
            ) : (
              <svg class="post__placeholder" viewBox="0 0 800 450" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="pLarge" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#A9BE8F"/>
                    <stop offset="100%" stop-color="#7d8866"/>
                  </linearGradient>
                </defs>
                <rect width="800" height="450" fill="url(#pLarge)"/>
                <g transform="translate(400, 225)">
                  <ellipse cx="-15" cy="-10" rx="25" ry="15" transform="rotate(-30 -15 -10)" fill="#E85D50" opacity="0.85"/>
                  <ellipse cx="15" cy="-25" rx="25" ry="15" transform="rotate(20 15 -25)" fill="#E85D50" opacity="0.85"/>
                  <ellipse cx="25" cy="5" rx="25" ry="15" transform="rotate(70 25 5)" fill="#E85D50" opacity="0.85"/>
                  <ellipse cx="-5" cy="20" rx="25" ry="15" transform="rotate(130 -5 20)" fill="#E85D50" opacity="0.85"/>
                  <circle cx="5" cy="-5" r="12" fill="#2d3a2c"/>
                </g>
              </svg>
            )}
          </a>
          <div class="post__content">
            <div class="post__meta">
              <span class="post__cat">{featured.data.category}</span>
              <span class="dot">·</span>
              <span>{fmtDate(featured.data.date)}</span>
            </div>
            <h3 class="post__title"><a href={`/journal/${featured.id}`}>{featured.data.title}</a></h3>
            <p class="post__excerpt">{featured.data.excerpt}</p>
            <span class="post__author">— {featured.data.author}</span>
          </div>
        </article>
      )}

      {journalPosts.map(post => (
        <article class="post">
          <a href={`/journal/${post.id}`} class="post__image">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.imageAlt || post.data.title} />
            ) : (
              <svg class="post__placeholder" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="#A9BE8F"/>
                <g transform="translate(200, 150)">
                  <ellipse cx="0" cy="-10" rx="18" ry="10" fill="#F4B6C2"/>
                  <ellipse cx="14" cy="6" rx="18" ry="10" transform="rotate(72 14 6)" fill="#F4B6C2"/>
                  <ellipse cx="4" cy="22" rx="18" ry="10" transform="rotate(144 4 22)" fill="#F4B6C2"/>
                  <ellipse cx="-14" cy="14" rx="18" ry="10" transform="rotate(216 -14 14)" fill="#F4B6C2"/>
                  <ellipse cx="-12" cy="-6" rx="18" ry="10" transform="rotate(288 -12 -6)" fill="#F4B6C2"/>
                  <circle cx="0" cy="4" r="7" fill="#E8B84A"/>
                </g>
              </svg>
            )}
          </a>
          <div class="post__content">
            <div class="post__meta">
              <span class="post__cat">{post.data.category}</span>
              <span class="dot">·</span>
              <span>{fmtDate(post.data.date)}</span>
            </div>
            <h3 class="post__title"><a href={`/journal/${post.id}`}>{post.data.title}</a></h3>
            <p class="post__excerpt">{post.data.excerpt}</p>
            <span class="post__author">— {post.data.author}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="journal__more">
      <a href="/journal" class="btn btn--ghost">
        <span>Read all stories</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L7 1m6 6l-6 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- PULL QUOTE -->
<section class="pullquote">
  <div class="pullquote__inner">
    <Wildflowers variant="bouquet" size={90} class="pullquote__ornament" />
    <p class="pullquote__text">
      We stopped waiting. We started planting.<br/>
      And then, after all those years — <em>everything bloomed.</em>
    </p>
    <p class="pullquote__attr">
      <span class="pullquote__attr-rule"></span>
      Kayla
      <span class="pullquote__attr-rule"></span>
    </p>
  </div>
</section>

<!-- SUBSCRIBE -->
<section id="subscribe" class="subscribe">
  <Wildflowers variant="poppy" size={90} class="subscribe__ornament-bg subscribe__ornament-bg--l" />
  <Wildflowers variant="cosmos" size={90} class="subscribe__ornament-bg subscribe__ornament-bg--r" />
  <div class="subscribe__inner">
    <h2 class="subscribe__title">
      A little note<br/>
      <em>every week</em>
    </h2>
    <p class="subscribe__lede">
      A short letter and a short devotional — in your inbox once a week, on Sundays. Just life at Prairie Creek, a verse I'm sitting with, and something simple to cook or make.
    </p>

    <form class="subscribe__form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" onsubmit="event.preventDefault(); this.querySelector('.subscribe__success').hidden=false; this.querySelector('.subscribe__fields').hidden=true;">
      <input type="hidden" name="form-name" value="newsletter" />
      <p style="display:none"><label>Don't fill this: <input name="bot-field" /></label></p>
      <div class="subscribe__fields">
        <label class="subscribe__label">
          <span>First name</span>
          <input type="text" name="name" required />
        </label>
        <label class="subscribe__label">
          <span>Email</span>
          <input type="email" name="email" required />
        </label>
        <button type="submit" class="btn btn--primary btn--full">
          <span>Send me Sundays</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L7 1m6 6l-6 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
      <div class="subscribe__success" hidden>
        <p><em>Thank you, friend. See you on Sunday.</em></p>
      </div>
    </form>
    <p class="subscribe__fine">No spam, no selling your email, ever. Unsubscribe any time.</p>
  </div>
</section>

</BaseLayout>
